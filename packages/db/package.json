{
  "name": "@redgest/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./enums": "./src/generated/prisma/enums.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests --exclude 'dist/**'",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "dotenv": "^17.3.1",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0"
  }
}
