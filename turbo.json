{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL", "DATABASE_URL_UNPOOLED", "NODE_ENV"],
  "globalPassThroughEnv": [
    "ANTHROPIC_API_KEY",
    "OPENAI_API_KEY",
    "REDDIT_CLIENT_ID",
    "REDDIT_CLIENT_SECRET",
    "TRIGGER_SECRET_KEY",
    "TRIGGER_PROJECT_ID",
    "TRIGGER_API_URL",
    "MCP_SERVER_API_KEY",
    "MCP_SERVER_PORT",
    "REDIS_URL",
    "RESEND_API_KEY",
    "SLACK_WEBHOOK_URL",
    "DELIVERY_EMAIL",
    "REDGEST_TEST_MODE",
    "LOG_LEVEL",
    "DIGEST_CRON",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "BETTER_AUTH_TRUSTED_ORIGINS",
    "REDGEST_ORG_ID",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "PGPASSWORD",
    "PGDATABASE",
    "PGHOST",
    "PGHOST_UNPOOLED",
    "PGUSER",
    "NEON_PROJECT_ID",
    "POSTGRES_URL",
    "POSTGRES_URL_NO_SSL",
    "POSTGRES_URL_NON_POOLING",
    "POSTGRES_PRISMA_URL",
    "POSTGRES_USER",
    "POSTGRES_HOST",
    "POSTGRES_PASSWORD",
    "POSTGRES_DATABASE",
    "VERCEL_OIDC_TOKEN",
    "EVENT_BUS_TRANSPORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^db:generate", "^db:deploy"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^db:generate"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^db:generate"],
      "outputs": []
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    }
  }
}
