# =========================
# Redgest Environment Config
# =========================
# Copy to .env and fill in your values.
# Only DATABASE_URL is required to boot the web UI.
# Reddit + Anthropic keys are required to generate digests.

# --- Required (to boot) ---

# PostgreSQL connection string (docker-compose runs on port 5433)
DATABASE_URL="postgresql://redgest:redgest@localhost:5433/redgest"

# --- Required (to generate digests) ---

# Anthropic API key (primary LLM provider)
ANTHROPIC_API_KEY=""

# Reddit API credentials (script-type app — https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# --- Optional ---

# Redis URL (for LLM response caching — local via docker-compose)
# REDIS_URL="redis://localhost:6379"

# MCP server bearer token (min 32 chars — only needed for MCP server)
# MCP_SERVER_API_KEY=""

# MCP server port
MCP_SERVER_PORT=3100

# OpenAI API key (fallback LLM provider)
# OPENAI_API_KEY=""

# Resend API key (email delivery)
# RESEND_API_KEY=""

# Delivery email address (recipient for digest emails)
# DELIVERY_EMAIL="you@example.com"

# Slack webhook URL (Slack delivery)
# SLACK_WEBHOOK_URL=""

# Trigger.dev secret key (uses in-process fallback without it)
# TRIGGER_SECRET_KEY=""

# Trigger.dev project ID
# TRIGGER_PROJECT_ID=""

# Trigger.dev API URL (self-hosted)
# TRIGGER_API_URL=""

# --- Defaults ---

# Digest schedule cron expression (default: 7 AM daily)
# DIGEST_CRON="0 7 * * *"

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Environment: development | production | test
NODE_ENV=development
